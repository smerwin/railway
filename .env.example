# Discord bot token from https://discord.com/developers/applications
# (Bot tab -> Reset Token). Requires the "Message Content Intent" enabled
# under Bot -> Privileged Gateway Intents -- the Gateway connection will
# be rejected (Invalid Session) without it, since MESSAGE_CONTENT is
# requested in the Identify payload.
DISCORD_BOT_TOKEN=

# The channel ID to stream. Enable Developer Mode in Discord
# (User Settings -> Advanced), then right-click the channel -> Copy Channel ID.
DISCORD_CHANNEL_ID=

# Optional. Railway sets this automatically in production.
PORT=3000
